# =========================
# Required
# =========================
BAIDU_AK=your_baidu_ak_here

# =========================
# Collector
# =========================
COLLECT_INTERVAL_SECONDS=60
WEATHER_INTERVAL_SECONDS=600
SAVE_RAW_JSON=true

# =========================
# API
# =========================
WEATHER_LOCATION=126.642464,45.756967
API_TIMEOUT_SECONDS=15

# =========================
# Kafka
# =========================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TRAFFIC_TOPIC=traffic_raw
KAFKA_WEATHER_TOPIC=weather_raw
KAFKA_RETRIES=3
KAFKA_ACKS=all

# =========================
# Paths
# =========================
PROJECT_ROOT=/mnt/d/bigdata/myproject
ROAD_LIST_FILE=/mnt/d/bigdata/myproject/data/config/road_list.csv
RAW_DIR=/mnt/d/bigdata/myproject/data/raw
LOG_DIR=/mnt/d/bigdata/myproject/logs

# =========================
# Streaming sink/output
# =========================
TRAFFIC_DETAIL_OUTPUT_PATH=hdfs://localhost:9000/traffic/history/traffic_detail
WEATHER_OUTPUT_PATH=hdfs://localhost:9000/traffic/history/weather
AVG_SPEED_OUTPUT_PATH=hdfs://localhost:9000/traffic/history/avg_speed

# =========================
# Streaming checkpoints
# =========================
TRAFFIC_DETAIL_CHECKPOINT=file:///mnt/d/bigdata/myproject/checkpoints/traffic_detail
WEATHER_CHECKPOINT=file:///mnt/d/bigdata/myproject/checkpoints/weather
AVG_SPEED_CHECKPOINT=file:///mnt/d/bigdata/myproject/checkpoints/avg_speed

# =========================
# Stack scripts (optional)
# =========================
SESSION_NAME=traffic-stack
KAFKA_HOME=/mnt/d/bigdata/apps/kafka
SPARK_HOME=/mnt/d/bigdata/apps/spark
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.0
WAIT_SECONDS=60
ENABLE_MONITOR=true
AUTO_ATTACH=true
DASHBOARD_INTERVAL=5
PORT_WAIT_SECONDS=20
TOPIC_TIMEOUT_MS=15000
STRICT=true

# =========================
# Prediction (SARIMA)
# =========================
PREDICTION_OUTPUT_PATH=hdfs://localhost:9000/traffic/prediction/sarima
PREDICTION_MODEL_DIR=/mnt/d/bigdata/myproject/models/sarima
PREDICTION_HISTORY_DAYS=21
PREDICTION_FORECAST_STEPS_15M=8
PREDICTION_FORECAST_STEPS_1M=30
PREDICTION_BIAS_WINDOW_MINUTES=60
PREDICTION_MIN_SAMPLES=96
PREDICTION_MISSING_RATE_THRESHOLD=0.20
PREDICTION_SPEED_MIN=0
PREDICTION_SPEED_MAX=150
PREDICTION_PEAK_WINDOWS=07:00-09:00,17:00-19:00
PREDICTION_BASELINE_YESTERDAY_WEIGHT=0.6
PREDICTION_BASELINE_LASTWEEK_WEIGHT=0.4
PREDICTION_SARIMAX_ORDER_15M=1,1,1
PREDICTION_SARIMAX_SEASONAL_ORDER_15M=1,1,1,96
PREDICTION_SARIMAX_ORDER_1M=1,0,1
PREDICTION_SARIMAX_SEASONAL_ORDER_1M=0,0,0,0
PREDICTION_ENABLE_SHORT_TERM=true
PREDICTION_RESIDUAL_CI_LOWER_Q=0.10
PREDICTION_RESIDUAL_CI_UPPER_Q=0.90
PREDICTION_TIMEZONE=Asia/Shanghai
